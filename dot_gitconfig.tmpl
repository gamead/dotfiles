[user]
  name  = {{ .name }}
  email = {{ .email }}

[core]
  editor   = nvim
  autocrlf = input

[pull]
  rebase = true

[alias]
  lg = log --oneline --graph --decorate --all
  st = status
  co = checkout

[init]
  defaultBranch = main

[credential]
{{- if .is_wsl }}
  helper = "/mnt/c/Program Files/Git/mingw64/bin/git-credential-manager.exe"
{{- else if eq .os "darwin" }}
  helper = osxkeychain
{{- else if eq .os "linux" }}
  # 优先尝试使用 github cli 作为凭证管理器
  # 如果没有安装 gh，则回退到 1 小时缓存
  helper = "!f() { test -x \"$(command -v gh)\" && gh auth git-credential \"$@\" || git credential-cache --timeout=3600 \"$@\"; }; f"
{{- end }}
