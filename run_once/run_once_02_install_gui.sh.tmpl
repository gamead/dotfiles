#!/bin/bash
set -e
echo ">>> 安装 GUI 应用..."

# ── 工具函数：按发行版安装单个软件 ───────────────
install_for_distro() {
  local pkg=$1
  local mapped=$2

  if [ "$mapped" = "__official_script__" ]; then
    # 需要官方源的软件
    case "$pkg" in
      vscode)
        if ! command -v code &>/dev/null; then
          wget -qO- https://packages.microsoft.com/keys/microsoft.asc \
            | gpg --dearmor | sudo tee /usr/share/keyrings/microsoft.gpg >/dev/null
          echo "deb [arch=amd64 signed-by=/usr/share/keyrings/microsoft.gpg] \
            https://packages.microsoft.com/repos/code stable main" \
            | sudo tee /etc/apt/sources.list.d/vscode.list
          sudo apt-get update -q && sudo apt-get install -y code
          echo "✅ vscode"
        else
          echo "⚠️  vscode 已安装，跳过"
        fi
        ;;
      docker)
        if ! command -v docker &>/dev/null; then
          curl -fsSL https://get.docker.com | sh
          sudo usermod -aG docker "$USER"
          # WSL2 无 systemd 用 service，实体机用 systemctl
          if grep -qi microsoft /proc/version 2>/dev/null; then
            echo "ℹ️  WSL2：用 'sudo service docker start' 启动 Docker"
          else
            sudo systemctl enable --now docker
          fi
          echo "✅ docker（重新登录后无需 sudo）"
        else
          echo "⚠️  docker 已安装，跳过"
        fi
        ;;
    esac
  else
    # 直接用包管理器安装
    if command -v yay &>/dev/null; then
      yay -Sy --noconfirm "$mapped" && echo "✅ $pkg" || echo "⚠️  $pkg 安装失败，跳过"
    elif command -v apt-get &>/dev/null; then
      sudo apt-get install -y "$mapped" && echo "✅ $pkg" || echo "⚠️  $pkg 安装失败，跳过"
    fi
  fi
}

{{- if eq .chezmoi.os "darwin" }}
# ════════════════════════════════════════════════
# macOS：Homebrew Cask 安装 common + darwin
# ════════════════════════════════════════════════
{{- range concat .packages.gui.common .packages.gui.darwin }}
brew install --cask {{ index $.packages.gui_packages.darwin . }} \
  && echo "✅ {{ . }}" || echo "⚠️  {{ . }} 安装失败，跳过"
{{- end }}

{{- else if eq .chezmoi.os "linux" }}

{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# ════════════════════════════════════════════════
# WSL2：两步处理
#   Step 1 - 查 wsl_install，决定装在哪里
#   Step 2 - 按发行版选包名和安装方式
# ════════════════════════════════════════════════

# ── Step 1：确保 winget 可用 ──────────────────────
if ! command -v winget.exe &>/dev/null; then
  echo ">>> winget 未找到，尝试自动安装..."
  powershell.exe -Command "
    Add-AppxPackage -Path 'https://aka.ms/Microsoft.VCLibs.x64.14.00.Desktop.appx'
    Add-AppxPackage -Path 'https://github.com/microsoft/winget-cli/releases/latest/download/Microsoft.DesktopAppInstaller_8wekyb3d8bbwe.msixbundle'
    Write-Host 'winget 安装完成'
  "
  if ! command -v winget.exe &>/dev/null; then
    echo "⚠️  winget 自动安装失败，请手动安装："
    echo "    https://apps.microsoft.com/detail/9NBLGGH4NNS1"
    exit 1
  fi
fi

# ── Step 2：遍历所有软件，按 wsl_install 分流 ────
# 合并 common + 平台列表（arch 或 debian）+ windows 列表
{{- $isArch := false }}
{{- if stat "/etc/arch-release" }}{{- $isArch = true }}{{- end }}

{{- $allPkgs := concat .packages.gui.common .packages.gui.windows }}
{{- if $isArch }}
{{- $allPkgs = concat $allPkgs .packages.gui.arch }}
{{- else }}
{{- $allPkgs = concat $allPkgs .packages.gui.debian }}
{{- end }}

{{- range $allPkgs }}
{{- $pkg := . }}
{{- $target := index $.wsl_install $pkg }}
{{- if eq $target "windows" }}
# {{ $pkg }} → Windows 侧（winget）
winget.exe install -e --id {{ index $.packages.gui_packages.winget $pkg }} \
  --accept-package-agreements --accept-source-agreements \
  && echo "✅ {{ $pkg }}（Windows）" || echo "⚠️  {{ $pkg }} 已安装或失败，跳过"

{{- else if eq $target "skip" }}
# {{ $pkg }} → WSL2 下跳过
echo "⏭️  {{ $pkg }} 在 WSL2 下跳过"

{{- else }}
# {{ $pkg }} → WSL2 内部安装（target: {{ if $target }}{{ $target }}{{ else }}wsl（默认）{{ end }}）
{{- if $isArch }}
install_for_distro "{{ $pkg }}" "{{ index $.packages.gui_packages.arch $pkg }}"
{{- else }}
install_for_distro "{{ $pkg }}" "{{ index $.packages.gui_packages.debian $pkg }}"
{{- end }}

{{- end }}
{{- end }}

{{- if $isArch }}
# Docker 服务（Arch WSL2 若开启了 systemd）
if pacman -Qi docker &>/dev/null; then
  sudo systemctl enable --now docker 2>/dev/null \
    || sudo service docker start 2>/dev/null || true
fi
{{- end }}

{{- else if stat "/etc/arch-release" }}
# ════════════════════════════════════════════════
# Arch 实体机：yay 安装 common + arch
# ════════════════════════════════════════════════
{{- range concat .packages.gui.common .packages.gui.arch }}
install_for_distro "{{ . }}" "{{ index $.packages.gui_packages.arch . }}"
{{- end }}

# Docker 服务启动
if pacman -Qi docker &>/dev/null; then
  sudo systemctl enable --now docker
  sudo usermod -aG docker "$USER"
  echo "ℹ️  Docker 已启动，重新登录后生效"
fi

# ── 中文输入法：fcitx5 ────────────────────────────
echo ">>> 安装 fcitx5 中文输入法..."
yay -Sy --noconfirm \
  fcitx5 fcitx5-chinese-addons fcitx5-qt fcitx5-gtk fcitx5-configtool

PROFILE="$HOME/.xprofile"
if ! grep -q "fcitx5" "$PROFILE" 2>/dev/null; then
  tee -a "$PROFILE" > /dev/null << 'FCITX'

# fcitx5 输入法
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export SDL_IM_MODULE=fcitx
fcitx5 -d --replace &
FCITX
fi
echo ">>> fcitx5 安装完成，重启后生效 ✅"

{{- else if command -v apt-get &>/dev/null }}
# ════════════════════════════════════════════════
# Debian / Ubuntu 实体机：安装 common + debian
# ════════════════════════════════════════════════
{{- range concat .packages.gui.common .packages.gui.debian }}
install_for_distro "{{ . }}" "{{ index $.packages.gui_packages.debian . }}"
{{- end }}

{{- end }}
{{- end }}

echo ">>> GUI 应用安装完成 ✅"
