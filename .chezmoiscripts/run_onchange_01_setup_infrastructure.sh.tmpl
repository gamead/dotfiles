#!/bin/bash
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
# config_hash: {{ (print .v2raya_nodes .v2raya_admin_password) | sha256sum }}

{{ template "scripts_common.sh" . }}
{{ template "get_pkg_name" . }}

set -euo pipefail

setup_traps "基础设施配置"
init_env

msg "=================================================="
msg "开始配置基础设施: \$(date)"
msg "=================================================="

# ── 0. 平台特定预处理 ──────────────────────────────
{{- if eq .os "darwin" }}
if ! command -v brew &>/dev/null; then
  msg ">>> 正在安装 Homebrew..."
  /bin/bash -c "\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "\$(/opt/homebrew/bin/brew shellenv)" || eval "\$(/usr/local/bin/brew shellenv)"
fi
{{- end }}

{{- if or .is_debian .is_redhat }}
# 动态处理第三方仓库 (从 packages.yaml 读取)
{{- \$all_requested_pkgs := "" }}
{{- range \$name, \$platforms := .infrastructure }}{{ \$all_requested_pkgs = printf "%s %s" \$all_requested_pkgs \$name }}{{ end }}
{{- range \$name, \$platforms := .packages }}{{ \$all_requested_pkgs = printf "%s %s" \$all_requested_pkgs \$name }}{{ end }}

{{- range \$pkg_name, \$handler := .package_handlers }}
  if echo "{{ \$all_requested_pkgs }}" | grep -q "\b{{ \$pkg_name }}\b"; then
    {{- if and $.is_debian (index \$handler "debian") }}
      if [ ! -f "/etc/apt/sources.list.d/{{ \$pkg_name }}.list" ]; then
        setup_debian_repo "{{ \$pkg_name }}" "{{ \$handler.debian.key_url }}" "{{ \$handler.debian.key_path }}" "{{ \$handler.debian.source }}"
      fi
    {{- else if and $.is_redhat (index \$handler "redhat") }}
      if [ ! -f "/etc/yum.repos.d/{{ \$pkg_name }}.repo" ]; then
        setup_redhat_repo "{{ \$pkg_name }}" "{{ \$handler.redhat.repo_url }}" "{{ index \$handler.redhat "key_url" | default "" }}"
      fi
    {{- end }}
  fi
{{- end }}
{{- end }}

# ── 1. 动态生成包列表 ──────────────────────────────
INFRA_PKGS=""
{{- range \$name, \$platforms := .infrastructure }}
  {{- \$pkg := template "get_pkg_name" (dict "root" \$ "item" \$platforms) -}}
  {{- if \$pkg }}
INFRA_PKGS="\$INFRA_PKGS {{ \$pkg }}"
  {{- end }}
{{- end }}
INFRA_PKGS=\$(echo "\$INFRA_PKGS" | xargs)

if [ -n "\$INFRA_PKGS" ]; then
  msg ">>> 安装基础设施包: \$INFRA_PKGS"
  {{- if .is_arch }}
    run_sudo pacman -S --needed --noconfirm base-devel git
    if ! command -v yay &>/dev/null; then
       msg "安装 yay (AUR helper)..."
       if [ "\$EUID" -eq 0 ]; then
         msg "⚠️  警告: 无法在 root 用户下直接安装 yay，请稍后手动安装。"
       else
         TMP_YAY=\$(mktemp -d)
         git clone https://aur.archlinux.org/yay.git "\$TMP_YAY"
         (cd "\$TMP_YAY" && makepkg -si --noconfirm)
         rm -rf "\$TMP_YAY"
       fi
    fi
    if command -v yay &>/dev/null; then
      yay -S --needed --noconfirm \$INFRA_PKGS
    else
      run_sudo pacman -S --needed --noconfirm \$INFRA_PKGS
    fi
  {{- else if .is_debian }}
    wait_for_apt_lock
    [ -z "\$(find /var/lib/apt/lists -mmin -60 2>/dev/null)" ] && run_sudo apt-get update -q || true
    run_sudo apt-get install -y \$INFRA_PKGS
  {{- else if .is_redhat }}
    run_sudo dnf install -y \$INFRA_PKGS
  {{- else if eq .os "darwin" }}
    brew install \$INFRA_PKGS
  {{- end }}
fi

# ── 2. 执行【基础设施】分类 Hook (数据驱动插件) ───────
{{- \$all_requested_pkgs := "" }}
{{- range \$name, \$platforms := .infrastructure }}{{ \$all_requested_pkgs = printf "%s %s" \$all_requested_pkgs \$name }}{{ end }}

{{- \$hooks_base := "hooks/infrastructure" }}
{{- range \$pkg_name, \$unused := .infrastructure }}
  {{- \$hook_rel_path := printf "%s/%s.sh" \$hooks_base \$pkg_name }}
  {{- \$hook_full_path := joinPath .chezmoi.sourceDir ".chezmoitemplates" \$hook_rel_path }}
  {{- if stat \$hook_full_path }}
    if echo "{{ \$all_requested_pkgs }}" | grep -q "\b{{ \$pkg_name }}\b"; then
       msg ">>> 发现基础设施 Hook: {{ \$pkg_name }}，正在执行..."
       {{ tpl (include (printf ".chezmoitemplates/%s" \$hook_rel_path)) \$ }}
    fi
  {{- end }}
{{- end }}

# ── 3. 安装 mise (开发工具管理器) ───────────────────────
msg ">>> 检查并安装 mise..."
if ! command -v mise &>/dev/null; then
  msg "    正在安装 mise..."
  mkdir -p "\$HOME/.local/bin"
  curl https://mise.run | sh
fi

# 确保 mise 命令可用并刷新指令索引
export PATH="\$HOME/.local/bin:\$PATH"
hash -r 2>/dev/null || true

# 信任仓库中的配置
SOURCE_CONFIG="{{ joinPath .chezmoi.sourceDir "dot_config/mise/config.toml" }}"
if [ -f "\$SOURCE_CONFIG" ] && command -v mise &>/dev/null; then
    msg "    正在信任 mise 配置文件: \$SOURCE_CONFIG"
    mise trust "\$SOURCE_CONFIG"
    
    msg "    正在使用 mise 安装/更新开发工具..."
    export PATH="\$HOME/.local/share/mise/shims:\$PATH"
    MISE_CONFIG_FILE="\$SOURCE_CONFIG" mise install --yes
fi
