#!/bin/bash
# 切换国内软件源（在安装任何软件之前执行）
# 默认使用清华源，可按需修改为其他镜像

set -euo pipefail

# ── 日志配置 ───────────────────────────────────────
LOG_FILE="$HOME/.chezmoi_install.log"
exec > >(tee -a "$LOG_FILE") 2>&1
echo "=================================================="
echo "开始执行系统镜像配置脚本: $(date)"
echo "=================================================="

{{- if eq .chezmoi.os "linux" }}

MIRROR_TUNA="https://mirrors.tuna.tsinghua.edu.cn"
MIRROR_ALIYUN="https://mirrors.aliyun.com"

# ── 检测发行版 ────────────────────────────────────
if command -v pacman &>/dev/null; then
  # ── Arch 系 ───────────────────────────────────────
  echo ">>> 切换 Arch 软件源为清华源..."

  # 备份原始镜像列表
  sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak

  # 写入清华源（放在最前面，优先使用）
  sudo tee /etc/pacman.d/mirrorlist > /dev/null << EOF
# 清华大学
Server = ${MIRROR_TUNA}/archlinux/\$repo/os/\$arch
# 阿里云
Server = ${MIRROR_ALIYUN}/archlinux/\$repo/os/\$arch
# 中科大
Server = https://mirrors.ustc.edu.cn/archlinux/\$repo/os/\$arch
EOF

  # 添加 archlinuxcn 源（AUR 常用依赖）
  if ! grep -q "archlinuxcn" /etc/pacman.conf; then
    sudo tee -a /etc/pacman.conf > /dev/null << EOF

[archlinuxcn]
Server = ${MIRROR_TUNA}/archlinuxcn/\$arch
EOF
    # 临时降低安全级别以安装 archlinuxcn-keyring
    sudo pacman -Sy
    sudo pacman -S --noconfirm --config <(cat /etc/pacman.conf | sed 's/SigLevel.*/SigLevel = Optional TrustAll/') archlinuxcn-keyring
  fi

  sudo pacman -Sy
  echo ">>> Arch 软件源切换完成 ✅"

elif command -v apt-get &>/dev/null; then
  # ── Debian / Ubuntu / WSL2 ────────────────────────
  echo ">>> 切换 apt 软件源为清华源..."

  # 使用 sed 原地替换，兼容旧版 sources.list 和 Ubuntu 24.04+ 的 ubuntu.sources
  
  if [ -f /etc/apt/sources.list ]; then
    sudo cp /etc/apt/sources.list /etc/apt/sources.list.bak
    # 替换 http(s)://archive.ubuntu.com/ubuntu/ 和 http(s)://security.ubuntu.com/ubuntu/
    sudo sed -i "s@http://.*archive.ubuntu.com@${MIRROR_TUNA}@g" /etc/apt/sources.list
    sudo sed -i "s@http://.*security.ubuntu.com@${MIRROR_TUNA}@g" /etc/apt/sources.list
    # Debian 替换
    sudo sed -i "s@http://deb.debian.org@${MIRROR_TUNA}@g" /etc/apt/sources.list
  fi

  if [ -f /etc/apt/sources.list.d/ubuntu.sources ]; then
    sudo cp /etc/apt/sources.list.d/ubuntu.sources /etc/apt/sources.list.d/ubuntu.sources.bak
    sudo sed -i "s@URIs: http://.*archive.ubuntu.com/ubuntu/@URIs: ${MIRROR_TUNA}/ubuntu/@g" /etc/apt/sources.list.d/ubuntu.sources
    sudo sed -i "s@URIs: http://.*security.ubuntu.com/ubuntu/@URIs: ${MIRROR_TUNA}/ubuntu/@g" /etc/apt/sources.list.d/ubuntu.sources
  fi

  if [ -f /etc/apt/sources.list.d/debian.sources ]; then
    sudo cp /etc/apt/sources.list.d/debian.sources /etc/apt/sources.list.d/debian.sources.bak
    sudo sed -i "s@URIs: http://deb.debian.org/debian@URIs: ${MIRROR_TUNA}/debian@g" /etc/apt/sources.list.d/debian.sources
  fi

  sudo apt-get update -q
  echo ">>> apt 软件源切换完成 ✅"

elif command -v dnf &>/dev/null; then
  # ── Fedora ────────────────────────────────────────
  echo ">>> 切换 dnf 软件源为清华源..."
  sudo sed -i \
    -e 's|https://download.example/pub/fedora/linux|'"${MIRROR_TUNA}"'/fedora-linux|g' \
    /etc/yum.repos.d/fedora.repo \
    /etc/yum.repos.d/fedora-updates.repo 2>/dev/null || true
  sudo dnf makecache
  echo ">>> dnf 软件源切换完成 ✅"

fi

{{- end }}
