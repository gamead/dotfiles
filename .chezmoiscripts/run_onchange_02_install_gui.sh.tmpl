#!/bin/bash
# gui install hash: {{ include ".chezmoiscripts/run_onchange_02_install_gui.sh.tmpl" | sha256sum }}
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

set -euo pipefail

# ── 日志配置 ───────────────────────────────────────
LOG_FILE="$HOME/.chezmoi_install.log"
sudo -v
exec >> "$LOG_FILE" 2>&1

# ── Terminal 反馈 ──────────────────────────────
msg() {
  echo "$@" >&2
  echo "$@" >/dev/tty 2>/dev/null || true
}

# ── 退出处理 ───────────────────────────────────
on_exit() {
  local ec=$?
  if [ $ec -eq 0 ]; then
    msg "=================================================="
    msg "✅ GUI 软件同步完成!"
    msg "   详细日志: $LOG_FILE"
    msg "   如果启用 GNOME 扩展，请注销后重新登录"
    msg "=================================================="
  else
    msg "=================================================="
    msg "❌ GUI 软件同步失败 (退出码: $ec)"
    msg "   排查方向:"
    msg "     1. 查看日志尾部: tail -30 $LOG_FILE"
    msg "     2. 检查包管理器是否有可用更新"
    msg "     3. 尝试手动安装失败的包"
    msg "=================================================="
  fi
}
trap on_exit EXIT

msg "=================================================="
msg "开始执行 GUI 安装脚本: $(date)"
msg "=================================================="

msg ">>> 正在同步 GUI 软件..."

{{- $has_gui_apps := false -}}
{{- range $app_name, $platforms := .gui_apps -}}
  {{- if or (index $platforms $.os) (index $platforms "common") -}}
    {{- $has_gui_apps = true -}}
  {{- end -}}
{{- end -}}

{{- if not $has_gui_apps }}
msg ">>> 提示: 未识别到适用于当前平台的 GUI 软件，跳过安装"
{{- else }}
# --- 自动启用 GNOME 托盘扩展 ---
{{- if and (eq .os "linux") (not .is_wsl) }}
  if command -v gsettings &>/dev/null && gsettings list-schemas | grep -q "org.gnome.shell"; then
    msg ">>> 检查 GNOME 托盘扩展状态..."
    
    UUID="appindicatorsupport@rgcjonas.gmail.com"
    ENABLED=$(gsettings get org.gnome.shell enabled-extensions)

    if [[ "$ENABLED" != *"$UUID"* ]]; then
      msg ">>> 正在添加 GNOME 托盘扩展..."
      if [[ "$ENABLED" == "@as []" ]] || [[ "$ENABLED" == "[]" ]]; then
        gsettings set org.gnome.shell enabled-extensions "['$UUID']"
      else
        gsettings set org.gnome.shell enabled-extensions "${ENABLED%]*}, '$UUID']"
      fi
      msg ">>> 扩展已启用，请注销并重新登录"
    else
      msg ">>> AppIndicator 扩展已启用，跳过"
    fi
  fi
{{- end }}

{{- range $app_name, $platforms := .gui_apps }}
  
  # --- 1. 确定目标平台和安装包 ---
  {{- $target_platform := "" -}}
  
  {{- if $.is_wsl }}
    {{- if index $platforms "winget" -}}{{- $target_platform = "winget" -}}
    {{- else if $.is_debian -}}{{- $target_platform = "debian" -}}
    {{- end }}
  {{- else if eq $.os "darwin" }}
    {{- if index $platforms "darwin" -}}{{- $target_platform = "darwin" -}}
    {{- end }}
  {{- else if eq $.os "linux" }}
    {{- if $.is_arch }}{{ if index $platforms "arch" }}{{ $target_platform = "arch" }}{{ end }}
    {{- else if $.is_debian }}{{ if index $platforms "debian" }}{{ $target_platform = "debian" }}{{ end }}
    {{- end }}
  {{- end }}

  # --- 2. 执行安装逻辑 ---
  {{- if $target_platform }}
    {{- $cmd := index $.install_commands $target_platform }}
    {{- $pkg := index $platforms $target_platform | default (index $platforms "common") }}
    
    {{- if $pkg }}
    msg "[{{ $app_name }}] 检测到适用平台: {{ $target_platform }} (包: {{ $pkg }})..."
    
    # 增加错误捕获，不因单个包失败而中断
    if ! (
      {{- if eq $target_platform "winget" }}
        if ! powershell.exe -Command "winget list --id {{ $pkg }}" &>/dev/null; then
          powershell.exe -Command "{{ $cmd }} {{ $pkg }}"
        fi
      {{- else if eq $target_platform "arch" }}
        if ! command -v yay &>/dev/null; then
          exit 1
        else
          {{ $cmd }} {{ $pkg }}
        fi
      {{- else }}
        {{ $cmd }} {{ $pkg }}
      {{- end }}
    ); then
      msg "⚠️  警告: {{ $app_name }} 安装失败，跳过"
    fi
    {{- end }}
  {{- end }}
{{- end }}

{{- end }}

msg ">>> GUI 软件同步完成"
