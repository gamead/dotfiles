#!/bin/bash
# mirrors config hash: {{ include ".chezmoiscripts/run_onchange_00_setup_mirrors.sh.tmpl" | sha256sum }}
# 切换国内软件源（动态并行测速 + 标记驱动型）

{{ template "scripts_common.sh" . }}

set -euo pipefail

# ── 配置 ───────────────────────────────────────────
MANAGED_TAG="__managed_by_envit__"

# 候选镜像列表 (从 packages.yaml 动态读取)
MIRRORS=(
{{- range .mirrors }}
  {{ . | quote }}
{{- end }}
)

# ── 退出处理 ───────────────────────────────────
cleanup() {
  [ -d "${TMP_DIR:-}" ] && rm -rf "$TMP_DIR" || true
}

setup_traps "软件源配置" "cleanup"

init_env

msg "=================================================="
msg "开始执行系统镜像配置脚本: $(date)"
msg "=================================================="

# 检查权限
if [[ $EUID -ne 0 ]] && ! command -v sudo &>/dev/null; then
   msg "⚠️  错误: 未找到 sudo 且非 root 用户，无法进行镜像配置。"
   exit 1
fi

# 并行测速函数
get_fastest_mirror() {
  if ! command -v curl &>/dev/null; then
    msg "错误: 需要 curl 进行测速，但未安装。"
    exit 1
  fi
  
  TMP_DIR=$(mktemp -d)
  chmod 777 "$TMP_DIR"
  local i=0
  
  local pids=()
  msg ">>> 正在并行检测镜像速度..."
  for url in "${MIRRORS[@]}"; do
    i=$((i+1))
    (
      # 使用 LC_ALL=C 确保时间格式统一
      local latency
      latency=$(LC_ALL=C curl -o /dev/null -s -f -L -w "%{time_connect}" --connect-timeout 2 "$url/" || echo 999)
      echo "$latency $url" > "$TMP_DIR/$i"
    ) &
    pids+=($!)
  done
  wait "${pids[@]}"

  
  local best
  best=$(cat "$TMP_DIR"/* | sort -n | head -n 1)
  local min_latency
  min_latency=$(echo "$best" | cut -d' ' -f1)
  local fastest_url
  fastest_url=$(echo "$best" | cut -d' ' -f2)
  
  if [ "$min_latency" = "999" ]; then
    echo "" # 返回空表示失败
  else
    echo "$fastest_url"
  fi
}

# 变量缓存
SELECTED_MIRROR=""
get_mirror() {
  if [ -z "$SELECTED_MIRROR" ]; then
    SELECTED_MIRROR=$(get_fastest_mirror)
    if [ -z "$SELECTED_MIRROR" ]; then
      msg "⚠️  警告: 未能检测到可用镜像，跳过镜像配置。"
      return 1
    fi
  fi
  echo "$SELECTED_MIRROR"
  return 0
}

# 安装 archlinuxcn-keyring
install_archlinuxcn_keyring() {
  if pacman -Qs archlinuxcn-keyring > /dev/null 2>&1; then
    return 0
  fi
  msg ">>> 正在安装 archlinuxcn 密钥环..."
  local tmpconfig
  tmpconfig=$(mktemp)
  sed 's/SigLevel.*/SigLevel = Optional TrustAll/' /etc/pacman.conf > "$tmpconfig"
  run_sudo pacman -Sy --noconfirm --config "$tmpconfig" archlinuxcn-keyring
  rm -f "$tmpconfig"
}

# 配置 archlinuxcn 源
setup_archlinuxcn() {
  local mirror_url="$1"
  [ -z "$mirror_url" ] && return 1

  # If archlinuxcn exists and is NOT managed by envit, skip (user-managed)
  if grep -q "^\[archlinuxcn\]" /etc/pacman.conf; then
    if grep -q "${MANAGED_TAG}" /etc/pacman.conf; then
      msg ">>> 检测到 envit 管理的 archlinuxcn 配置，重新应用..."
    else
      msg ">>> archlinuxcn 已在 pacman.conf 中定义，跳过追加。"
      return 0
    fi
  else
    msg ">>> 正在配置 archlinuxcn 软件源..."
  fi

  local tmp_pacman=$(mktemp)
  run_sudo cp /etc/pacman.conf "$tmp_pacman"
  run_sudo chmod 666 "$tmp_pacman"

  # Remove old envit-managed block before re-applying
  if grep -q "${MANAGED_TAG}" "$tmp_pacman"; then
    awk -v tag="# ${MANAGED_TAG}" '
      $0 == tag { skip = 1; next }
      skip && /^\[archlinuxcn\]/ { next }
      skip && /^\[/ { skip = 0 }
      skip { next }
      { print }
    ' "$tmp_pacman" > "${tmp_pacman}.clean"
    run_sudo mv "${tmp_pacman}.clean" "$tmp_pacman"
  fi

  cat << EOF >> "$tmp_pacman"

# ${MANAGED_TAG}
[archlinuxcn]
Server = ${mirror_url}/archlinuxcn/\$arch
EOF
  run_sudo mv "$tmp_pacman" /etc/pacman.conf
  install_archlinuxcn_keyring
}

{{- if eq .os "linux" }}

# ── 检测发行版 ────────────────────────────────────
if command -v pacman &>/dev/null; then
  # ── Arch / Manjaro ────────────────────────────────
  if [ -f /etc/manjaro-release ]; then
    if grep -q "${MANAGED_TAG}" /etc/pacman.d/mirrorlist 2>/dev/null 2>&1; then
      msg ">>> Manjaro 软件源已由 envit 管理，跳过。"
    else
      msg ">>> 检测到 Manjaro，正在切换国内镜像源..."
      run_sudo pacman-mirrors --country China --api --protocol https || true
      echo "# ${MANAGED_TAG}" | run_sudo tee -a /etc/pacman.d/mirrorlist > /dev/null
    fi
  else
    if grep -q "${MANAGED_TAG}" /etc/pacman.d/mirrorlist 2>/dev/null; then
      msg ">>> Arch 软件源已由 envit 管理，跳过。"
    else
      FASTEST_URL=$(get_mirror)
      msg ">>> 正在配置 Arch 软件源 (最优: ${FASTEST_URL})..."
      local tmp_mirror=$(mktemp)
      {
        echo "# ${MANAGED_TAG}"
        echo "Server = ${FASTEST_URL}/archlinux/\$repo/os/\$arch"
        for url in "${MIRRORS[@]}"; do
          if [ "$url" != "$FASTEST_URL" ]; then
            echo "Server = ${url}/archlinux/\$repo/os/\$arch"
          fi
        done
      } > "$tmp_mirror"
      run_sudo mv "$tmp_mirror" /etc/pacman.d/mirrorlist
    fi
  fi
  if FASTEST_URL=$(get_mirror); then
    setup_archlinuxcn "$FASTEST_URL"
  else
    msg ">>> 网络不可达，跳过 archlinuxcn 配置。"
  fi
  msg ">>> 正在同步软件包数据库..."
  # 如果同步失败，打印警告但不终止整个脚本，允许继续配置
  if ! run_sudo pacman -Sy --noconfirm; then
    msg "⚠️  警告: 软件包数据库同步失败，请检查网络或镜像源。"
  else
    msg ">>> 软件包数据库同步完成"
  fi

elif command -v apt-get &>/dev/null; then
  # ── Debian / Ubuntu ───────────────────────────────
  if ! FASTEST_URL=$(get_mirror); then
    msg ">>> 跳过 apt 软件源配置。"
  else
    wait_for_apt_lock
    shopt -s nullglob
    SOURCES_FILES=(/etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources)
    
    for src in "${SOURCES_FILES[@]}"; do
      [ -f "$src" ] || continue
      if grep -q "${MANAGED_TAG}" "$src"; then
        msg ">>> $src 已由 envit 管理，跳过。"
        continue
      fi
      
      msg ">>> 正在更新 $src (最优: ${FASTEST_URL})..."
      local tmp_src=$(mktemp)
      run_sudo cp "$src" "$tmp_src"
      
      # 替换传统格式
      run_sudo sed -E -i "s@https?://([^/ ]+)\.debian\.org@${FASTEST_URL}@g" "$tmp_src"
      run_sudo sed -E -i "s@https?://([^/ ]+)\.ubuntu\.com@${FASTEST_URL}@g" "$tmp_src"
      run_sudo sed -E -i "s@https?://deb\.debian\.org@${FASTEST_URL}@g" "$tmp_src"
      # 兼容 DEB822 格式
      run_sudo sed -E -i "s@URIs: https?://([^/ ]+)\.debian\.org@URIs: ${FASTEST_URL}@g" "$tmp_src"
      run_sudo sed -E -i "s@URIs: https?://([^/ ]+)\.ubuntu\.com@URIs: ${FASTEST_URL}@g" "$tmp_src"
      
      run_sudo chmod 666 "$tmp_src"
      echo "# ${MANAGED_TAG}" >> "$tmp_src"
      run_sudo mv "$tmp_src" "$src"
    done
    shopt -u nullglob
    
    run_sudo apt-get update -q
  fi

elif command -v dnf &>/dev/null || command -v yum &>/dev/null; then
  # ── RedHat / CentOS / Fedora ──────────────────────
  PM=$(command -v dnf || command -v yum)
  if ! FASTEST_URL=$(get_mirror); then
    msg ">>> 跳过 RedHat 系软件源配置。"
  else
    shopt -s nullglob
    for repo in /etc/yum.repos.d/*.repo; do
      [ -f "$repo" ] || continue
      if grep -q "${MANAGED_TAG}" "$repo"; then
        msg ">>> $repo 已由 envit 管理，跳过。"
        continue
      fi
      
      msg ">>> 正在更新 $repo ..."
      local tmp_repo=$(mktemp)
      run_sudo cp "$repo" "$tmp_repo"
      
      # 处理 Fedora
      if [ -f /etc/fedora-release ]; then
        run_sudo sed -E -e 's|^metalink=|#metalink=|g' \
             -e "s|^#?baseurl=https?://download\.fedoraproject\.org/pub/fedora/linux|baseurl=${FASTEST_URL}/fedora/linux|g" \
             -i "$tmp_repo" || true
      # 处理 CentOS / RHEL
      elif [ -f /etc/centos-release ] || [ -f /etc/redhat-release ]; then
        run_sudo sed -E -e 's|^mirrorlist=|#mirrorlist=|g' \
             -e "s|^#?baseurl=https?://mirror\.centos\.org/centos|baseurl=${FASTEST_URL}/centos|g" \
             -i "$tmp_repo" || true
      fi
      
      run_sudo chmod 666 "$tmp_repo"
      echo "# ${MANAGED_TAG}" >> "$tmp_repo"
      run_sudo mv "$tmp_repo" "$repo"
    done
    shopt -u nullglob
    
    run_sudo "$PM" makecache
  fi
fi

{{- else if eq .os "darwin" }}
# ── macOS Homebrew 镜像配置 ─────────────────────────
if command -v brew &>/dev/null; then
  if ! FASTEST_URL=$(get_mirror); then
    msg ">>> 跳过 Homebrew 镜像配置。"
  else
    msg ">>> 正在配置 Homebrew 镜像 (最优: ${FASTEST_URL})..."
    
    # 替换规则：
    # 1. brew.git (Homebrew 核心)
    # 2. homebrew-core.git
    # 3. homebrew-cask.git
    
    export HOMEBREW_API_DOMAIN="${FASTEST_URL}/homebrew-bottles/api"
    export HOMEBREW_BOTTLE_DOMAIN="${FASTEST_URL}/homebrew-bottles"
    
    # 尝试设置环境变量到 shell 配置文件
    BREW_REPO=$(brew --repo)
    git -C "$BREW_REPO" remote set-url origin "${FASTEST_URL}/homebrew/brew.git" || true
    
    CORE_REPO="$(brew --repo homebrew/core)"
    [ -d "$CORE_REPO" ] && git -C "$CORE_REPO" remote set-url origin "${FASTEST_URL}/homebrew/homebrew-core.git" || true
    
    CASK_REPO="$(brew --repo homebrew/cask)"
    [ -d "$CASK_REPO" ] && git -C "$CASK_REPO" remote set-url origin "${FASTEST_URL}/homebrew/homebrew-cask.git" || true
    
    msg ">>> Homebrew 镜像配置完成"
  fi
fi
{{- end }}
exit 0
