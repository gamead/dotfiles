#!/bin/bash
# summary hash: {{ include ".chezmoiscripts/run_onchange_99_summary.sh.tmpl" | sha256sum }}
# 全流程汇总提示

{{ template "scripts_common.sh" . }}

set -euo pipefail

# 汇总脚本不使用标准 trap，仅初始化环境
init_env

# 收集请求安装的所有包名 (用于条件显示)
{{- $all_requested_pkgs := "" }}
{{- range $name, $platforms := .infrastructure }}{{ $all_requested_pkgs = printf "%s %s" $all_requested_pkgs $name }}{{ end }}
{{- range $name, $platforms := .packages }}{{ $all_requested_pkgs = printf "%s %s" $all_requested_pkgs $name }}{{ end }}

msg ""
msg "=============================================="
msg "  ✅  🎉  全 部 配 置 完 成 ！"
msg "=============================================="
msg ""

# ── 安装统计 ──────────────────────────────────
if [ -f "$LOG_FILE" ]; then
  SUCCESS_COUNT=$(grep -c "✅" "$LOG_FILE" || echo 0)
  FAIL_COUNT=$(grep -c "❌" "$LOG_FILE" || echo 0)
  msg "  ── 模块安装统计 ──"
  msg "    ✅ 成功模块: ${SUCCESS_COUNT}"
  if [ "${FAIL_COUNT}" -gt 0 ]; then
    msg "    ❌ 失败模块: ${FAIL_COUNT} (请检查日志)"
  else
    msg "    ✨ 所有模块均已成功执行"
  fi
  msg ""
fi

msg "  以下操作使所有配置生效:"
msg ""

# ── Shell 配置 ──────────────────────────────────
msg "  ── Shell 配置 ──"
msg "    重新加载:  source ~/.bashrc"
msg "    或直接新开一个终端标签页"
msg ""

# ── mise ────────────────────────────────────────
if command -v mise &>/dev/null; then
  TOOL_COUNT=$(mise ls 2>/dev/null | wc -l)
  msg "  ── mise 开发工具 (${TOOL_COUNT} 个) ──"
  msg "    确认已激活:  mise ls"
  msg "    重新加载:    eval \"\$(mise activate bash)\""
  msg "    部分语言工具可能需要新终端才能生效"
  msg ""
fi

# ── Docker (仅当请求安装了 docker 时显示) ───────────
{{- if contains "docker" $all_requested_pkgs }}
if groups "$USER" 2>/dev/null | grep -q "\bdocker\b"; then
  msg "  ── Docker 权限 ──"
  msg "    当前用户已在 docker 组中"
  msg "    立即生效:  newgrp docker"
  msg "    永久生效:  注销并重新登录"
  msg ""
fi
{{- end }}

# ── GNOME 扩展 (根据配置列表动态显示) ───────────────
{{- if .gnome_settings.extensions }}
if command -v gsettings &>/dev/null; then
  msg "  ── GNOME 扩展状态 ──"
  {{- range .gnome_settings.extensions }}
  UUID="{{ . }}"
  if gsettings get org.gnome.shell enabled-extensions 2>/dev/null | grep -q "$UUID"; then
    msg "    ✅ 已激活: $UUID"
  else
    msg "    ⚠️  待手动激活: $UUID"
  fi
  {{- end }}
  msg "    注销并重新登录后生效"
  msg ""
fi
{{- end }}

# ── 镜像 / 包管理器 ──────────────────────────────
HAS_PACMAN=$(command -v pacman &>/dev/null && echo 1 || echo 0)
HAS_APT=$(command -v apt-get &>/dev/null && echo 1 || echo 0)
HAS_BREW=$(command -v brew &>/dev/null && echo 1 || echo 0)

if [ "$HAS_PACMAN" = "1" ]; then
  msg "  ── 包管理器 (pacman) ──"
  msg "    软件源镜像已配置，直接使用即可"
  msg ""
fi
if [ "$HAS_APT" = "1" ]; then
  msg "  ── 包管理器 (apt) ──"
  msg "    软件源镜像已配置，直接使用即可"
  msg ""
fi
if [ "$HAS_BREW" = "1" ]; then
  msg "  ── 包管理器 (Homebrew) ──"
  msg "    镜像已配置 (TUNA)，环境变量已注入 custom.sh"
  msg ""
fi

# ── 最终建议 ────────────────────────────────────
msg "  -----------------------------------------"
msg "  快速刷新全部配置:"
msg "    source ~/.bashrc && exec newgrp docker"
msg ""
msg "  查看完整安装日志:"
msg "    less $LOG_FILE"
msg ""
msg "=============================================="
msg ""
