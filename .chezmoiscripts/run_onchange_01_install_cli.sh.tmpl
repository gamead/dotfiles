#!/bin/bash
# cli install hash: {{ include ".chezmoiscripts/run_onchange_01_install_cli.sh.tmpl" | sha256sum }}
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
# mise config hash: {{ include "dot_config/mise/config.toml" | sha256sum }}

set -euo pipefail

# ── 日志配置 ───────────────────────────────────────
LOG_FILE="$HOME/.chezmoi_install.log"
sudo -v
exec >> "$LOG_FILE" 2>&1

# ── Terminal 反馈 ──────────────────────────────
msg() {
  echo "$@" >&2
  echo "$@" >/dev/tty 2>/dev/null || true
}

# ── 退出处理 ───────────────────────────────────
on_exit() {
  local ec=$?
  if [ $ec -eq 0 ]; then
    msg "=================================================="
    msg "✅ CLI 工具安装完成!"
    msg "   详细日志: $LOG_FILE"
    msg "   使工具生效: source ~/.bashrc  或重开终端"
    msg "=================================================="
  else
    msg "=================================================="
    msg "❌ CLI 工具安装失败 (退出码: $ec)"
    msg "   排查方向:"
    msg "     1. 查看日志尾部: tail -30 $LOG_FILE"
    msg "     2. 检查网络连接和 sudo 权限"
    msg "     3. 确认未手动安装的工具无冲突"
    msg "     4. 如果 mise 报错，尝试手动运行: mise install"
    msg "=================================================="
  fi
}
trap on_exit EXIT

msg "=================================================="
msg "开始执行 CLI 安装脚本: $(date)"
msg "=================================================="

# ── 1. 动态生成包列表 ──────────────────────────────
PACKAGES=""
{{- range $name, $platforms := .cli }}
  {{- $pkg := "" -}}
  {{- if index $platforms $.os }}{{ $pkg = index $platforms $.os }}
  {{- else if index $platforms $.distro }}{{ $pkg = index $platforms $.distro }}
  {{- else if index $platforms "common" }}{{ $pkg = index $platforms "common" }}
  {{- end }}
  {{- if $pkg }}
PACKAGES="$PACKAGES {{ $pkg }}"
  {{- end }}
{{- end }}

msg ">>> [1/3] 正在安装系统基础包: $PACKAGES"

{{- if eq .os "darwin" }}
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
brew install $PACKAGES

{{- else if eq .os "linux" }}
if command -v pacman &>/dev/null; then
  # Arch 系统
  sudo pacman -S --needed --noconfirm base-devel git
  if ! command -v yay &>/dev/null; then
    msg "正在安装 yay (AUR helper)..."
    rm -rf /tmp/yay
    git clone https://aur.archlinux.org/yay.git /tmp/yay
    (cd /tmp/yay && makepkg -si --noconfirm)
    rm -rf /tmp/yay
  fi
  yay -S --needed --noconfirm $PACKAGES
elif command -v apt-get &>/dev/null; then
  # Debian/Ubuntu 系统
  [ -z "$(find /var/lib/apt/lists -mmin -60 2>/dev/null)" ] && sudo apt-get update -q || true
  sudo apt-get install -y $PACKAGES
fi
{{- end }}

msg ">>> [2/3] 确保 mise 已安装..."
if ! command -v mise &>/dev/null; then
  curl https://mise.run | sh
fi

msg ">>> [3/3] 正在使用 mise 安装开发工具及常用 CLI..."
export PATH="$HOME/.local/bin:$PATH"

# 使用仓库中的源配置进行安装
SOURCE_CONFIG="{{ joinPath .chezmoi.sourceDir "dot_config/mise/config.toml" }}"

if [ -f "$SOURCE_CONFIG" ]; then
    msg "使用仓库源配置进行安装: $SOURCE_CONFIG"
    mise trust "$SOURCE_CONFIG"
    # mise install --yes --config "$SOURCE_CONFIG"
    MISE_CONFIG_FILE="$SOURCE_CONFIG" mise install --yes
else
    msg "⚠️ 无法找到配置文件: $SOURCE_CONFIG"
    exit 1
fi

msg ">>> 所有工具安装/更新完成"
