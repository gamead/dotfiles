#!/bin/bash
# Shell config source injector
# Ensures a non-destructive, idempotent injection of custom shell config.

{{ template "scripts_common.sh" . }}

set -euo pipefail

setup_traps "Shell 配置注入"
init_env

msg "=================================================="
msg "开始配置 Shell 环境: $(date)"
msg "=================================================="

MARKER_START="# ── EnvIt Custom Config Start ──"
MARKER_END="# ── EnvIt Custom Config End ──"
LOAD_CMD='[ -f "$HOME/.config/shell/custom.sh" ] && source "$HOME/.config/shell/custom.sh"'

inject_config() {
    local rc_file="$1"
    if [ ! -f "$rc_file" ]; then
        return
    fi

    if ! grep -q "$MARKER_START" "$rc_file"; then
        msg ">>> 正在向 $rc_file 注入 EnvIt 配置..."
        {
            echo ""
            echo "$MARKER_START"
            echo "$LOAD_CMD"
            echo "$MARKER_END"
        } >> "$rc_file"
    else
        msg ">>> $rc_file 已包含 EnvIt 配置，跳过"
    fi
}

inject_config "$HOME/.bashrc"
inject_config "$HOME/.zshrc"
msg ">>> Shell 配置注入完成"
